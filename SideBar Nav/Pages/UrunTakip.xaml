<Page x:Class="SideBar_Nav.Pages.UrunTakip"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SideBar_Nav.Pages"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="UrunTakip">
    <Grid>
        <!-- ARKA PLAN: Image -->
        <Image Source="/Images/marble.jpg"
               Grid.RowSpan="3"
               Stretch="Fill"
               IsHitTestVisible="False"
               Panel.ZIndex="-1"
               RenderOptions.BitmapScalingMode="HighQuality"
               SnapsToDevicePixels="True"
               UseLayoutRounding="True">
            <Image.CacheMode>
                <BitmapCache/>
            </Image.CacheMode>
        </Image>
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <!-- Reader IP alanı -->
                <RowDefinition Height="*"/>
                <!-- Ana içerik -->
            </Grid.RowDefinitions>

            <!-- 📌 Sayfa Başlığı -->
            <TextBox Grid.Row="0" 
                     Text="Ürün Kayıt Ekranı"
                     FontSize="24"
                     FontWeight="Bold"
                     HorizontalAlignment="Left"
                     Margin="20,20,0,0"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="Black"
                     IsReadOnly="True"
                     TextAlignment="Left"/>
            <!-- 📡 Reader IP ve Bağlantı Butonları -->
            <Border Grid.Row="1" Background="White" BorderBrush="#FFB197FC" BorderThickness="1" CornerRadius="6" Padding="10" Margin="20,20,20,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Width="1100" Margin="15,0,0,0">
                    <Grid Width="140" Height="24" Margin="0">
                        <TextBox Name="IPTextBox" Width="140" Height="24" GotFocus="IPTextBox_GotFocus" LostFocus="IPTextBox_LostFocus"/>
                        <TextBlock Name="IPPlaceholder" Text="Reader IP Address" Foreground="Gray" VerticalAlignment="Center" Margin="5,0,0,0" IsHitTestVisible="False"/>
                    </Grid>

                    <Button Content="Connect Reader" Width="120" Height="30" Click="buttonConnect_Click" Margin="10,0,10,0"/>
                    <Button Content="Disconnect Reader" Width="120" Height="30" Click="buttonDisconnect_Click" Margin="10,0,10,0"/>
                    <Button x:Name="buttonStart" Content="Start Reader" Width="120" Height="30" Click="buttonStart_Click" Margin="10,0,10,0"/>
                    <Button x:Name="buttonStop" Content="Stop Reader" Width="120" Height="30" Click="buttonStop_Click" Margin="10,0,10,0"/>
                    <Button x:Name="btnSettings" Content="Ayarlar" Width="120" Height="30" Click="SettingsButton_Click" Margin="10,0,10,0"/>

                </StackPanel>
            </Border>

            <!-- 🧾 Ürün Bilgisi + Rapor -->
            <Grid Grid.Row="2" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Genel Ürün Bilgileri -->
                <Border Grid.Row="0" Grid.Column="0" Background="White" BorderBrush="#FFB197FC" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,10,0">

                    <StackPanel>
                        <TextBlock Text="Genel Ürün Bilgileri" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="EPC:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="5">
                                <TextBox x:Name="txtEPC" Width="200" FontSize="12"/>
                                <Button Content="..." Width="30" Margin="5,0,0,0" Click="BtnEpcList_Click"/>
                            </StackPanel>

                            <TextBlock Text="Barkod No:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="5">
                                <TextBox x:Name="txtBarkodNo" Width="100" FontSize="12"/>
                                <Button x:Name="btnBarkodOku" Content="Barkod Oku" Click="BtnBarkodOku_Click" Margin="6,0,6,0" />
                                <TextBlock Text="COM Port:" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cmbComPorts" Width="80" Margin="0,0,6,0"
          SelectionChanged="cmbComPorts_SelectionChanged"/>
                                <Button x:Name="btnRefreshCom" Content="Yenile" Click="btnRefreshCom_Click" Margin="0,0,6,0"/>
                                <Button x:Name="btnConnectCom" Content="Bağlan" Click="btnConnectCom_Click" Margin="0,0,6,0"/>
                                <Button x:Name="btnDisconnectCom" Content="Kes" Click="btnDisconnectCom_Click" Margin="0,0,6,0" IsEnabled="False"/>
                                <!-- Mevcut yerleşimine uygun bir yere ekle -->
                                <Button x:Name="btnBarcodeSettings"
    Content="Barkod Ayarları"
    Margin="6,0,0,0"
    Click="btnBarcodeSettings_Click"/>


                                <TextBlock x:Name="lblComStatus" Text="Kapalı" Foreground="DarkRed" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>



                            <TextBlock Text="Bandıl No:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12"/>
                            <TextBox x:Name="txtBandilNo" Grid.Row="2" Grid.Column="1" Margin="5" FontSize="12"/>

                            <TextBlock Text="Plaka No:" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12"/>
                            <TextBox x:Name="txtPlakaNo" Grid.Row="3" Grid.Column="1" Margin="5" FontSize="12"/>

                            <TextBlock Text="Ürün Tipi:" Grid.Row="4" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="cmbUrunTipi" Grid.Row="4" Grid.Column="1" Margin="5" FontSize="12">
                                <ComboBoxItem Content="Bitmiş Mamül"/>
                                <ComboBoxItem Content="Yarı Mamül"/>
                            </ComboBox>

                            <StackPanel Orientation="Horizontal" Grid.Row="5" Grid.ColumnSpan="2">
                                <TextBlock Text="Ürün Türü:" Grid.Row="5" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12"/>
                                <ComboBox x:Name="cmbUrunTuru" Width="200" Margin="90,0,0,0" DisplayMemberPath="UrunTuru" SelectedValuePath="YogunlukKatsayisi" SelectedIndex="-1" SelectionChanged="AlanTonajOtomatikHesapla"/>
                                <Button Content="+" Width="30"  Click="BtnUrunTuruEkle_Click" Margin="5,0,0,0"/>
                            </StackPanel>


                            <StackPanel Orientation="Horizontal" Grid.Row="6" Margin="0,5,0,0" Grid.ColumnSpan="2">
                                <TextBlock Text="Yüzey İşlemi:" Grid.Row="6" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12" />
                                <ComboBox x:Name="cmbYuzeyIslemi" Grid.Row="6" Grid.Column="1"  Width="200" Margin="78,0,10,0" Height="25"/>
                                <Button Content="+" Width="31" Click="BtnYuzeyIslemiEkle_Click" Margin="-5,0,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Seleksiyon:" Grid.Row="7" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12"/>
                            <TextBox x:Name="txtSeleksiyon" Grid.Row="7" Grid.Column="1" Margin="5" FontSize="12"/>

                            <TextBlock Text="Üretim Tarihi:" Grid.Row="8" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12"/>
                            <DatePicker x:Name="dateUretimTarihi" Grid.Row="8" Grid.Column="1" Margin="5"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Stok Plaka Ölçüleri -->
                <Border Grid.Row="0" Grid.Column="1" Background="White" BorderBrush="#FFB197FC" BorderThickness="1" CornerRadius="6" Padding="8" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Stok Plaka Ölçüleri" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Kalınlık (cm):" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12"/>
                            <TextBox x:Name="txtKalınlık" Grid.Row="0" Grid.Column="1" Margin="5" FontSize="12" TextChanged="AlanTonajOtomatikHesapla"/>

                            <TextBlock Text="En (cm):" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12" />
                            <TextBox x:Name="txtEn" Grid.Row="1" Grid.Column="1" Margin="5" FontSize="12" TextChanged="AlanTonajOtomatikHesapla"/>

                            <TextBlock Text="Boy (cm):" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12"/>
                            <TextBox x:Name="txtBoy" Grid.Row="2" Grid.Column="1" Margin="5" FontSize="12" TextChanged="AlanTonajOtomatikHesapla"/>

                            <TextBlock Text="Plaka Adedi:" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12"/>
                            <TextBox x:Name="txtPlakaAdedi" Grid.Row="3" Grid.Column="1" Margin="5" FontSize="12" TextChanged="AlanTonajOtomatikHesapla"/>

                            <TextBlock Text="Alan (m²):" Grid.Row="4" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12"/>
                            <TextBlock x:Name="txtAlan" Text="-" Grid.Row="4" Grid.Column="1" Margin="5" FontSize="12"/>

                            <TextBlock Text="Tonaj (kg):" Grid.Row="5" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontSize="12"/>
                            <TextBlock x:Name="txtTonaj" Text="-" Grid.Row="5" Grid.Column="1" Margin="5" FontSize="12"/>


                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">


                            <Button Content="Kayıt Et" Width="100" Height="30" Margin="5" Click="BtnKaydet_Click"/>
                            <Button Content="Temizle" Width="100" Height="30" Margin="5" Click="BtnTemizle_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Üretim Raporları -->
                <Border Grid.Row="1" Grid.ColumnSpan="2" Background="White" BorderBrush="#FFB197FC" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="Üretim Raporları" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ComboBox x:Name="cmbTarihSecimi" Width="150" Margin="0,0,10,0" SelectionChanged="cmbTarihSecimi_SelectionChanged">
                                <ComboBoxItem Content="Günlük" />
                                <ComboBoxItem Content="Haftalık"/>
                                <ComboBoxItem Content="Aylık"/>
                                <ComboBoxItem Content="Yıllık"/>
                            </ComboBox>
                            <DatePicker x:Name="dateSecim" SelectedDateChanged="dateSecim_SelectedDateChanged"/>
                        </StackPanel>

                        <DataGrid x:Name="dataGridRapor"
                          AutoGenerateColumns="True"                             
                          IsReadOnly="True"
                          CellEditEnding="dataGridRapor_CellEditEnding"
                          Height="350"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                            <!-- <Button x:Name="btnGuncelle" Content="Seçili Ürünü Güncelle" Width="150" Height="30" Margin="0,5,5,5" Click="btnGuncelle_Click" HorizontalAlignment="Left"/> -->
                            <Button x:Name="btnYenile" Content="Yenile" Width="150" Height="30" Margin="0,5,5,5" Click="btnYenile_Click" HorizontalAlignment="Left"/>
                            <Button x:Name="btnPdfRapor" Content="PDF Rapor Oluştur" Width="170" Height="30" Margin="0,5,5,5" Click="btnPdfRapor_Click" HorizontalAlignment="Left"/>
                            <Button x:Name="btnExcelRapor" Content="Excel Rapor Oluştur" Width="170" Height="30" Margin="0,5,5,5" Click="btnExcelRapor_Click" HorizontalAlignment="Left"/>
                            <Button x:Name="btnSil" Content="Seçili Ürünü Stoktan Sil" Width="170" Height="30" Margin="0,5,5,5" Click="btnSil_Click" HorizontalAlignment="Left"/>


                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
    
</Page>
