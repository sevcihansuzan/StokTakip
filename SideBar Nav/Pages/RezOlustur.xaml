<Page x:Class="SideBar_Nav.Pages.RezOlustur"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SideBar_Nav.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      
      Title="RezOlustur">
    <Grid>
        <!-- ARKA PLAN: Image -->
        <Image Source="/Images/marble.jpg"
               Grid.RowSpan="3"
               Stretch="Fill"
               IsHitTestVisible="False"
               Panel.ZIndex="-1"
               RenderOptions.BitmapScalingMode="HighQuality"
               SnapsToDevicePixels="True"
               UseLayoutRounding="True">
            <Image.CacheMode>
                <BitmapCache/>
            </Image.CacheMode>
        </Image>
        <ScrollViewer>
            <StackPanel Margin="20">

                <!-- Başlık -->
                <TextBlock Text="Rezervasyon Oluşturma Ekranı"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,15"/>
                <Border Background="White" CornerRadius="5" BorderBrush="#B197FC" BorderThickness="2">
                    <!-- Üst Form Bilgileri -->
                    <Grid  Margin="10" >

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="İşlem Tarihi" Grid.Column="0" FontWeight="Bold" Margin="0,0,0,5"/>
                        <DatePicker Grid.Column="0" Grid.Row="1" x:Name="dateTarih" Margin="0,2,10,3"/>

                        <TextBlock Text="Rezervasyon Kodu" Grid.Column="1" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Grid.Column="1" Grid.Row="1" x:Name="txtRezervasyonKodu" Margin="0,2,10,3"/>

                        <TextBlock Text="Rezervasyon No" Grid.Column="2" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Grid.Column="2" Grid.Row="1" x:Name="txtRezervasyonNo" Margin="0,2,10,3"/>

                        <TextBlock Text="Alıcı Firma" Grid.Column="3" FontWeight="Bold" Margin="0,0,10,30" Grid.RowSpan="2"/>
                        <ComboBox x:Name="cmbAliciFirma" Grid.Column="3" Grid.Row="1" Margin="0,2,10,3"
              IsEditable="True"
              StaysOpenOnEdit="True"
              IsTextSearchEnabled="False"
              KeyUp="CmbAliciFirma_KeyUp"/>
                        <Button Content="Firma Seç veya Ekle" Grid.Column="4" Grid.Row="1" Click="BtnFirmaSec_Click" Margin="0,5,9,5"/>



                        <TextBlock Text="Rezervasyon Sorumlusu" Grid.Column="5" FontWeight="Bold" Margin="10,0,-11,5"/>
                        <TextBox Grid.Column="5" Grid.Row="1" x:Name="txtRezervasyonSorumlusu" IsReadOnly="True" Margin="10,2,-13,3"/>

                        <Button Content="Temizle" Grid.Column="6" Grid.Row="1" Click="BtnTemizle_Click" Margin="20,5,5,5"/>

                    </Grid>

                </Border>


                <!-- Filtre Alanı -->
                <GroupBox Background="White" Header="Ürün Filtreleme" FontWeight="Bold" Margin="0,0,0,0" BorderBrush="#B197FC" BorderThickness="2">
                    <WrapPanel Margin="10">
                        <StackPanel Margin="5">
                            <TextBlock Text="EPC ile Filtrele"/>
                            <TextBox x:Name="txtFiltreEPC" Width="120"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="Barkod ile Filtrele"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBox x:Name="txtFiltreBarkod" Width="120"/>
                                <Button x:Name="btnFiltreBarkodOkuRez" Content="Barkodu Oku" Margin="5,0,0,0" Click="BtnFiltreBarkodOkuRez_Click"/>
                            </StackPanel>
                            <TextBlock x:Name="txtBarcodeStatusRez" Text="Barkod okuyucu: Kapalı" Foreground="DarkRed" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="Bandıl No ile Filtrele"/>
                            <TextBox x:Name="txtFiltreBandil" Width="120"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="Tarih ile Filtrele"/>
                            <DatePicker x:Name="dateFiltreTarih" Width="120"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="Tarih Periyodu"/>
                            <ComboBox x:Name="cmbTarihSecimi" Width="120" SelectionChanged="cmbTarihSecimi_SelectionChanged">
                                <ComboBoxItem Content="Günlük" />
                                <ComboBoxItem Content="Haftalık" />
                                <ComboBoxItem Content="Aylık" />
                                <ComboBoxItem Content="Yıllık" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="Durum Filtrele"/>
                            <ComboBox x:Name="cmbDurumFiltre" Width="120">
                                <ComboBoxItem Content="Hepsi" IsSelected="True"/>
                                <ComboBoxItem Content="Stokta"/>
                                <ComboBoxItem Content="Onay Bekliyor"/>
                                <ComboBoxItem Content="Onaylandı"/>
                                <ComboBoxItem Content="Sevkiyat Tamamlandı"/>
                                <ComboBoxItem Content="İptal"/>
                            </ComboBox>
                        </StackPanel>
                        <Button Content="Filtreleri Sıfırla" Width="150" Height="20" Margin="5,15,5,5" Click="BtnFiltreSifirla_Click"/>

                    </WrapPanel>
                </GroupBox>

                <!-- Ürün Seçim DataGrid -->
                <!-- Başlık -->
                <TextBlock Text="Ürünler"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="Black"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,0"/>
                <Border BorderBrush="#B197FC" BorderThickness="2" CornerRadius="5" Margin="0,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#B197FC" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <DataGrid x:Name="dataGrid1" AutoGenerateColumns="True" Height="260"
                      IsReadOnly="True" SelectionMode="Single"/>
                </Border>

                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,10,0,0" >
                    <Button Content="Rezervasyona Ekle" Click="BtnRezervasyonaEkle_Click" Width="150" Height="30" Margin="0,0,0,10"/>
                </StackPanel>
                <!-- Rezervasyona Eklenenler DataGrid -->
                <Border BorderBrush="#B197FC" BorderThickness="2" CornerRadius="5" Margin="0,0,0,10">
                    <Border.Effect>
                        <DropShadowEffect Color="#B197FC" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <DataGrid x:Name="dataGrid2" AutoGenerateColumns="True" Height="300"
                      IsReadOnly="True" SelectionMode="Extended"/>
                </Border>

                <!-- Alt Butonlar (dikey hizalı) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0" >
                    <Button Content="Rezervasyondan Çıkar" Width="180" Height="30" Click="BtnRezervasyondanCikar_Click"/>
                    <Button Content="Boyutları Güncelle" Width="180" Height="30" Click="BtnBoyutGuncelle_Click" Margin="10,0,0,0"/>
                    <Button Content="Rezervasyon Oluştur" Width="180" Height="30" Background="DarkGreen" Foreground="White" Click="BtnOlustur_Click" Margin="10,0,0,0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
    
</Page>
