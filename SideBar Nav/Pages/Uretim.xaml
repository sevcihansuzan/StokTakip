<Page x:Class="SideBar_Nav.Pages.Uretim"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SideBar_Nav.Pages"
      xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
      xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Uretim">

    <Grid Background="#FF101010" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Akıllı Fabrika Görselleştirme, dosya boyutu çok büyük, eklenecek"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0 0 0 10" />

        <Border Grid.Row="1"
                Background="#FF1E1E1E"
                CornerRadius="8"
                BorderBrush="#FF2F2F2F"
                BorderThickness="1">
            <wfi:WindowsFormsHost x:Name="unityHost" Margin="5">
                <wf:Panel x:Name="unityPanel" BackColor="Black" />
            </wfi:WindowsFormsHost>
        </Border>
    </Grid>
</Page>
