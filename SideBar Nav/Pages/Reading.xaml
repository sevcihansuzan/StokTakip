<Page x:Class="SideBar_Nav.Pages.Reading"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SideBar_Nav.Pages"
      mc:Ignorable="d"
      Title="Reading"
      
      d:DesignWidth="1200" d:DesignHeight="800">
    <Grid>
        <!-- ARKA PLAN: Image -->
        <Image Source="/Images/marble.jpg"
               Grid.RowSpan="3"
               Stretch="Fill"
               IsHitTestVisible="False"
               Panel.ZIndex="-1"
               RenderOptions.BitmapScalingMode="HighQuality"
               SnapsToDevicePixels="True"
               UseLayoutRounding="True">
            <Image.CacheMode>
                <BitmapCache/>
            </Image.CacheMode>
        </Image>
        <Grid >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sol sütun: Butonlar -->
            <Border Grid.Column="0" BorderThickness="1" BorderBrush="#FFB197FC" CornerRadius="6" Margin="10" Padding="10">
                <StackPanel>
                    <TextBlock Text="Reading" FontFamily="Segoe UI" FontSize="20" Foreground="#FFB197FC" FontWeight="ExtraBold" HorizontalAlignment="Center" Margin="0,0,0,10" />
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <Button x:Name="buttonStart" Content="Start Reader" Width="100" Height="30" Click="buttonStart_Click" Margin="0,0,0,10" />
                        <Button x:Name="buttonStop" Content="Stop Reader" Width="100" Height="30" Click="buttonStop_Click" />
                        <Button x:Name="buttonClear" Content="Clear" Click="buttonClear_Click" Margin="0,10,0,0" Width="100" Height="30"/>
                        <StackPanel Orientation="Vertical" Grid.Row="0" Margin="0,0,0,0" HorizontalAlignment="Left">
                            <TextBlock Text="Filter EPC: " VerticalAlignment="Center" Margin="0,10,5,0"/>
                            <TextBox x:Name="epcFilterTextBox" Width="100" VerticalAlignment="Center" TextChanged="epcFilterTextBox_TextChanged"/>
                            <Button Content="Save (JSON)" Width="100" Margin="0,10,0,0" Click="buttonSaveJson_Click"/>
                            <Button Content="Export to Excel" Width="100" Margin="0,10,0,0" Click="buttonExportExcel_Click"/>

                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Sağ sütun: Info ve DataGrid -->
            <Grid Grid.Column="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Information bölgesi -->
                <Border Grid.Row="0" BorderThickness="1" BorderBrush="#FFB197FC" CornerRadius="6" Margin="0,0,0,10" Padding="10">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal" Margin="10" HorizontalAlignment="Left">
                            <!-- Rf Mode -->
                            <StackPanel Margin="10,0" Orientation="Vertical">
                                <TextBlock Text="Reader Mode" FontWeight="Bold" />
                                <TextBlock x:Name="txtRfMode" Text="-" />
                            </StackPanel>

                            <!-- Search Mode -->
                            <StackPanel Margin="10,0" Orientation="Vertical">
                                <TextBlock Text="Search Mode" FontWeight="Bold" />
                                <TextBlock x:Name="txtSearchMode" Text="-" />
                            </StackPanel>

                            <!-- Report Mode -->
                            <StackPanel Margin="10,0" Orientation="Vertical">
                                <TextBlock Text="Report Mode" FontWeight="Bold" />
                                <TextBlock x:Name="txtReportMode" Text="-" />
                            </StackPanel>

                            <!-- Session -->
                            <StackPanel Margin="10,0" Orientation="Vertical">
                                <TextBlock Text="Session" FontWeight="Bold"/>
                                <TextBlock x:Name="txtSession" Text="-" />
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </Border>


                <!-- DataGrid bölgesi -->
                <Border Grid.Row="1" BorderThickness="1" BorderBrush="#FFB197FC" CornerRadius="6" >
                    <Border.Effect>
                        <DropShadowEffect Color="#B197FC" BlurRadius="12" ShadowDepth="2"/>
                    </Border.Effect>
                    <DataGrid x:Name="dataGridTags"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      Margin="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      CanUserResizeColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="EPC" Binding="{Binding EPC}" Width="*" />
                            <DataGridTextColumn Header="Seen Count" Binding="{Binding SeenCount}" Width="*" />
                            <DataGridTextColumn Header="First Seen" Binding="{Binding FirstSeenTime}" Width="*" />
                            <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeenTime}" Width="*" />
                            <DataGridTextColumn Header="RSSI (dBm)" Binding="{Binding RSSIPeak}" Width="*" />
                            <DataGridTextColumn Header="Phase" Binding="{Binding Phase}" Width="*" />
                            <DataGridTextColumn Header="Antenna(s)" Binding="{Binding AntennaPortDisplay}" Width="*"/>
                            <DataGridTextColumn Header="Location" Binding="{Binding AntennaPortNameDisplay}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

        </Grid>
    </Grid>
    
</Page>
