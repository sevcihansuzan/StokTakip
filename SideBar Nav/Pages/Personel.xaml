<Page x:Class="SideBar_Nav.Pages.Personel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="1600"
      Title="Personel">
    <Grid>
        <!-- ARKA PLAN: Image -->
        <Image Source="/Images/marble.jpg"
               Grid.RowSpan="3"
               Stretch="Fill"
               IsHitTestVisible="False"
               Panel.ZIndex="-1"
               RenderOptions.BitmapScalingMode="HighQuality"
               SnapsToDevicePixels="True"
               UseLayoutRounding="True">
            <Image.CacheMode>
                <BitmapCache/>
            </Image.CacheMode>
        </Image>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">
            <Grid 
          UseLayoutRounding="True"
          SnapsToDevicePixels="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Başlık -->
                <Border Grid.Row="0" Background="#ffffff" Padding="16"
                BorderBrush="#e5e7eb" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Personel Bilgileri" FontSize="22" FontWeight="SemiBold" Foreground="#111827"/>
                        <TextBlock Text="  •  " FontSize="18" Foreground="#6b7280"/>
                        <TextBlock FontSize="18" Foreground="#6b7280"
                           Text="{Binding DataContext.DisplayName,
                                          RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </Border>

                <!-- İçerik -->
                <Border Grid.Row="1" Margin="16" Padding="20" Background="White"
                CornerRadius="12" BorderBrush="#e5e7eb" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#B197FC" BlurRadius="12" ShadowDepth="2"/>
                    </Border.Effect>
                    <Grid>
                        <!-- 3. sütunu ekledik: avatar paneli -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="520"/>
                            <ColumnDefinition Width="*" MinWidth="520"/>
                            <ColumnDefinition Width="Auto" MinWidth="280"/>
                            <!-- Avatar -->
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- 0 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 1 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 2 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 3 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 4 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 5 -->
                            <RowDefinition Height="*"/>
                            <!-- 6 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 7 spacer -->
                            <RowDefinition Height="Auto"/>
                            <!-- 8 buttons -->
                        </Grid.RowDefinitions>

                        <!-- Email (RO) -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,0,6"
                           Text="E-posta" Foreground="#6b7280"/>
                        <TextBox   Grid.Row="1" Grid.Column="0" Margin="0,0,16,12"
                           x:Name="txtEmail" IsReadOnly="True" Background="#f9fafb" MinHeight="32"/>

                        <!-- Ad -->
                        <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,6"
                           Text="Ad" Foreground="#6b7280"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"
                           x:Name="txtAd" MinHeight="32"/>

                        <!-- Pozisyon -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,6"
                           Text="Pozisyon" Foreground="#6b7280"/>
                        <TextBox   Grid.Row="3" Grid.Column="0" Margin="0,0,16,12"
                           x:Name="txtPozisyon" MinHeight="32"  IsReadOnly="True"/>

                        <!-- Telefon -->
                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,8,0,6"
                           Text="Telefon" Foreground="#6b7280"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" Margin="0,0,0,12"
                           x:Name="txtPhone" MinHeight="32"/>

                        <!-- Zaman Damgaları (RO) -->
                        <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,8,16,6">
                            <TextBlock Text="Oluşturma" Foreground="#6b7280"/>
                            <TextBox x:Name="txtCreated" IsReadOnly="True" Background="#f9fafb" MinHeight="32"/>
                        </StackPanel>
                        <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,8,0,6">
                            <TextBlock Text="Güncelleme" Foreground="#6b7280"/>
                            <TextBox x:Name="txtUpdated" IsReadOnly="True" Background="#f9fafb" MinHeight="32"/>
                        </StackPanel>

                        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Son Giriş" Foreground="#6b7280" Margin="0,0,12,0"/>
                            <TextBox x:Name="txtLastSignIn" IsReadOnly="True" Width="240" Background="#f9fafb" MinHeight="32"/>
                        </StackPanel>

                        <!-- Avatar paneli (sürükle-bırak) -->
                        <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="6"
                        Margin="16,0,0,0" Padding="12"
                        BorderBrush="#e5e7eb" BorderThickness="1" CornerRadius="8"
                        AllowDrop="True"
                        Drop="AvatarDrop"
                        DragEnter="AvatarDragEnter"
                        DragOver="AvatarDragOver">
                            <StackPanel>
                                <Image x:Name="imgAvatar"
                               Width="180" Height="180"
                               Stretch="UniformToFill"
                               Margin="0,0,0,8"
                               HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="Fotoğrafı buraya sürükleyip bırakın (JPG/PNG/WEBP)"
                                   TextAlignment="Center"
                                   Opacity="0.7" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Uyarı / Durum -->
                        <TextBlock Grid.Row="6" Grid.ColumnSpan="3" x:Name="lblStatus"
                           Foreground="#ef4444" FontWeight="SemiBold"/>

                        <!-- Butonlar -->
                        <WrapPanel Grid.Row="8" Grid.ColumnSpan="3" 
                           HorizontalAlignment="Right"
                           ItemHeight="36" Margin="20">
                            <Button x:Name="btnPassword" Content="Şifre Oluştur/Yenile"
                            Padding="14,6" Height="36" MinWidth="150"
                            Margin="0,0,5,0"
                            Click="btnPassword_Click"/>
                            <Button x:Name="btnRefresh" Content="Yenile"
                            Padding="14,6" Height="36" MinWidth="110"
                            Margin="0,0,5,0"
                            Click="btnRefresh_Click"/>
                            <Button x:Name="btnSave" Content="Kaydet"
                            Padding="14,6" Height="36" MinWidth="110"
                            Margin="0,0,0,0"
                            Background="#2563eb" Foreground="White"
                            Click="btnSave_Click"/>
                        </WrapPanel>

                        <!-- Busy overlay tüm grid'i kaplasın -->
                        <Border x:Name="busyOverlay"
                        Grid.RowSpan="9" Grid.ColumnSpan="3"
                        Background="#80000000" Visibility="Collapsed" CornerRadius="12">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Background="#111827"  Opacity="0.95" >
                                <TextBlock Text="İşlem yapılıyor..." Foreground="White" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
    
</Page>
