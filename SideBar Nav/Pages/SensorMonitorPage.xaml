<Page x:Class="SideBar_Nav.Pages.SensorMonitorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SideBar_Nav.Pages"
      xmlns:oxy="http://oxyplot.org/wpf"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1400"
      Title="SensorMonitorPage"
      Background="White">
    

    <Page.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#e0e0e0" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="5" />
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="MinHeight" Value="25" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#a6d5f7" />
                    <Setter Property="Foreground" Value="Black" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
            <Setter Property="Padding" Value="5" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="14" FontWeight="Bold" Foreground="#333"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
        </Style>
    </Page.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="ENDÜSTRİ 4.0 ÜRETİM TAKİP SİSTEMİ" Grid.Row="0" 
                       Foreground="#333" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#28a745" CornerRadius="8" Padding="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="VERİM (%)" Foreground="White" Opacity="0.9" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                            <TextBlock Text="{Binding Verim, StringFormat={}{0:0.0}%}" Foreground="White" FontSize="26" FontWeight="Bold" />
                            <TextBlock Text="+0.5%" Foreground="#cfffd9" FontSize="11" VerticalAlignment="Bottom" Margin="5,0,0,4"/>
                        </StackPanel>
                        <ProgressBar Value="90" Height="4" Foreground="#1e7e34" Background="#50ffffff" BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#2d89ef" CornerRadius="8" Padding="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="KWH/ÜRÜN" Foreground="White" Opacity="0.9" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                            <TextBlock Text="{Binding KwhUrun, StringFormat={}{0:0.00}}" Foreground="White" FontSize="26" FontWeight="Bold" />
                            <TextBlock Text="-1.1" Foreground="#dcebfb" FontSize="11" VerticalAlignment="Bottom" Margin="5,0,0,4"/>
                        </StackPanel>
                        <ProgressBar Value="70" Height="4" Foreground="#1b60a8" Background="#50ffffff" BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="#e3a21a" CornerRadius="8" Padding="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="SÜRE/ÜRÜN (s)" Foreground="White" Opacity="0.9" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                            <TextBlock Text="{Binding SureUrun, StringFormat={}{0:0.0}}" Foreground="White" FontSize="26" FontWeight="Bold" />
                            <TextBlock Text="-0.2" Foreground="#fff3cd" FontSize="11" VerticalAlignment="Bottom" Margin="5,0,0,4"/>
                        </StackPanel>
                        <ProgressBar Value="45" Height="4" Foreground="#b07d12" Background="#50ffffff" BorderThickness="0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="Aktif Ürün Seç:" FontSize="14" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <ComboBox Width="200" Padding="5" Text="Bir ürün seçin..." IsEditable="True">
                    <ComboBoxItem Content="PRD_0251" />
                    <ComboBoxItem Content="PRD_0252" />
                    <ComboBoxItem Content="PRD_0253" />
                </ComboBox>
            </StackPanel>

            <GroupBox Grid.Row="3" Header="Ham Veri Kayıtları" Margin="0,0,0,15">
                <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          ItemsSource="{Binding SensorDataList}" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ÜrünID" Binding="{Binding UrunID}" Width="*" />
                        <DataGridTextColumn Header="Ürün konumu" Binding="{Binding SensorNoktasi}" Width="*" />
                        <DataGridTextColumn Header="Zaman" Binding="{Binding Zaman, StringFormat=HH:mm:ss}" Width="0.7*" />
                        <DataGridTextColumn Header="V(t)" Binding="{Binding Vrms}" Width="0.7*" />
                        <DataGridTextColumn Header="I(t)" Binding="{Binding Irms}" Width="0.7*" />
                        <DataGridTextColumn Header="P(W)" Binding="{Binding Guc}" Width="*" />
                        <DataGridTextColumn Header="Sıcaklık (°C)" Binding="{Binding Sicaklik}" Width="0.8*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Grid.Row="4" Header="Son Üretim Kayıtları">
                <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          ItemsSource="{Binding ProductTraceList}" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ürün ID" Binding="{Binding UrunID}" Width="0.7*" />
                        <DataGridTextColumn Header="Üretim Süresi (dk)" Binding="{Binding UretimSuresi}" Width="1.15*" />
                        <DataGridTextColumn Header="tgiriş(s)" Binding="{Binding GirisZamani}" Width="0.6*" />
                        <DataGridTextColumn Header="tçıkış(s)" Binding="{Binding CikisZamani}" Width="0.6*" />
                        <DataGridTextColumn Header="Ort. Güç(W)" Binding="{Binding OrtalamaGuc}" Width="*" />
                        <DataGridTextColumn Header="Verim (%)" Binding="{Binding Verim}" Width="0.9*" />
                        <DataGridTextColumn Header="Makine Durumu" Binding="{Binding MakineDurumu}" Width="1.1*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Ürün Bazlı Verim" FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,15" />

            <!--[grafik alanı]-->
            <Border Grid.Row="1" Background="#F9F9F9" BorderBrush="#cccccc" BorderThickness="1" CornerRadius="5" Margin="0,0,0,15">
                <oxy:PlotView Model="{Binding MyPlotModel}" />
                <!--<Grid>
                    <TextBlock Text="[Grafik Alanı]" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#AAAAAA" />
                </Grid>-->
            </Border>

            <StackPanel Grid.Row="2">
                <Border Background="#28a745" CornerRadius="5" Margin="0,0,0,10" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Data="M0,5 L5,10 L15,0" Stroke="White" StrokeThickness="3" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <TextBlock Grid.Column="1" Text="SAĞLIKLI" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Background="#E0E0E0" CornerRadius="5" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="!" FontSize="24" FontWeight="Bold" Foreground="#555" VerticalAlignment="Center" Margin="5,0,15,0"/>
                        <TextBlock Grid.Column="1" Text="BAKIM GEREKLİ" Foreground="#555" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>