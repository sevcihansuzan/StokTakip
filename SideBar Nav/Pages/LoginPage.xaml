<Page x:Class="SideBar_Nav.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="1600"
      Title="Giriş">
    <Grid>

        <!-- SATIRLAR -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ARKA PLAN: Image -->
        <Image Source="/Images/loginImage.png"
               Grid.RowSpan="3"
               Stretch="Fill"
               IsHitTestVisible="False"
               Panel.ZIndex="-1"
               RenderOptions.BitmapScalingMode="HighQuality"
               SnapsToDevicePixels="True"
               UseLayoutRounding="True">
            <Image.CacheMode>
                <BitmapCache/>
            </Image.CacheMode>
        </Image>


        <!-- Başlık -->
        <TextBlock Text="AFSUAM RFID Stok Takip"
                   FontFamily="Bahnschrift"
                   FontSize="36"
                   FontWeight="Bold"
                   Foreground="#1E3A8A"
                   HorizontalAlignment="Center"
                   Margin="0,200,0,0">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black"
                                  BlurRadius="8"
                                  ShadowDepth="2"
                                  Opacity="0.6"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- Kart -->
        <Border Grid.Row="1"
                BorderBrush="#FFB197FC"
                Background="#1A1F2B"
                CornerRadius="16"
                Padding="28"
                Margin="400,0,400,0"
                >
            <Border.Effect>
                <DropShadowEffect Color="#B197FC" BlurRadius="12" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Hesabına Giriş Yap"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#F3F4F6"/>

                <!-- Email -->
                <!-- Email -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="Email" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                    <Grid>
                        <TextBox x:Name="txtEmail"
             Height="40"
             Padding="12,0"
             VerticalContentAlignment="Center"
             Background="#111827"
             Foreground="#E5E7EB"
             BorderBrush="#374151"
             BorderThickness="1"
             CaretBrush="#E5E7EB"
             FontSize="14"
             TextChanged="txtEmail_TextChanged"/>
                        <!-- Placeholder -->
                        <TextBlock x:Name="phEmail"
               Text="ornek@firma.com"
               Foreground="#6B7280"
               IsHitTestVisible="False"
               Margin="15,0,0,0"
               VerticalAlignment="Center"
               FontSize="{Binding ElementName=txtEmail, Path=FontSize}"
               Visibility="Visible"/>
                    </Grid>
                </StackPanel>

                <!-- Password -->
                <!-- Password -->
                <StackPanel Grid.Row="4">
                    <TextBlock Text="Parola" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                    <Grid>
                        <PasswordBox x:Name="txtPassword"
                 Height="40"
                 Padding="12,0"
                 VerticalContentAlignment="Center"
                 Background="#111827"
                 Foreground="#E5E7EB"
                 BorderBrush="#374151"
                 BorderThickness="1"
                 FontSize="14"
                 PasswordChanged="txtPassword_PasswordChanged"/>
                        <!-- Placeholder -->
                        <TextBlock x:Name="phPassword"
               Text="Parolanız"
               Foreground="#6B7280"
               IsHitTestVisible="False"
               Margin="15,0,0,0"
               VerticalAlignment="Center"
               FontSize="{Binding ElementName=txtPassword, Path=FontSize}"
               Visibility="Visible"/>
                    </Grid>
                </StackPanel>


                <!-- Hata / durum etiketi -->
                <TextBlock x:Name="lblStatus"
                           Grid.Row="6"
                           Foreground="#FCA5A5"
                           Text=""
                           TextWrapping="Wrap"/>

                <!-- Butonlar -->
                <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" >
                    <Button x:Name="btnForgot"
                            Content="Şifremi Unuttum"
                            Click="btnForgot_Click"
                            Margin="0,0,8,0"
                            Background="Transparent"
                            BorderBrush="#374151"
                            Foreground="#A5B4FC"
                            Padding="12,6"
                            Visibility="Hidden"/>
                    <Button x:Name="btnRegister"
                            Content="Kayıt Ol"
                            Click="btnRegister_Click"
                            Margin="0,0,8,0"
                            Background="Transparent"
                            BorderBrush="#374151"
                            Foreground="#E5E7EB"
                            Padding="12,6"
                            Visibility="Hidden"/>
                    <Button x:Name="btnGoogle"
                            Content="Google ile Giriş"
                            Click="btnGoogle_Click"
                            Margin="0,0,8,0"
                            Background="#DB4437"
                            BorderBrush="#B23B31"
                            Foreground="White"
                            Padding="12,6"/>
                    <Button x:Name="btnLogin"
                            Content="Giriş Yap"
                            Click="btnLogin_Click"
                            Margin="0,0,8,0"
                            Background="#4F46E5"
                            BorderBrush="#4338CA"
                            Foreground="White"
                            IsDefault="True"
                            Padding="18,8"/>
                    <Button x:Name="btnLogout"
                            Content="Çıkış Yap"
                            Click="btnLogout_Click"
                            Margin="0,0,8,0"
                            Background="Transparent"
                            BorderBrush="#374151"
                            Foreground="#E5E7EB"
                            Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Progress Overlay -->
        <Border x:Name="busyOverlay"
                Grid.RowSpan="3"
                Background="#80000000"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" >
                <ProgressBar IsIndeterminate="True" Width="200" Height="6"/>
                <TextBlock Text="İşlem yapılıyor..." Margin="0,8,0,0" Foreground="#E5E7EB" HorizontalAlignment="Center"/>
                <!-- İptal Butonu -->
                <Button x:Name="btnCancelGoogle"
                        Content="İşlemi İptal Et"
                        Click="btnCancelGoogle_Click"
                        Margin="0,12,0,0"
                        Background="#B91C1C"
                        BorderBrush="#7F1D1D"
                        Foreground="White"
                        Padding="12,6"
                        
                        Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
