<Page x:Class="SideBar_Nav.Pages.Sevkiyat"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1200"
      Title="Sevkiyat">

    <Grid>
        <!-- Arka plan -->
        <Grid.Background>
            <ImageBrush ImageSource="/Images/marble.jpg" Stretch="UniformToFill" AlignmentX="Center" AlignmentY="Center"/>
        </Grid.Background>

        <!-- Ana düzen -->
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Üst bilgi -->
                <RowDefinition Height="Auto"/>
                <!-- Rezervasyon detay -->
                <RowDefinition Height="*"/>
                <!-- Uygun -->
                <RowDefinition Height="*"/>
                <!-- Uygunsuz -->
            </Grid.RowDefinitions>

            <!-- 📦 Üst Bilgiler -->
            <StackPanel Grid.Row="0" Background="White" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Rezervasyon No:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" Height="15"/>
                <TextBox x:Name="txtRezervasyonNo" Width="150" IsReadOnly="True" Margin="0,0,16,0" Height="22" />
                <TextBlock Text="Alıcı Firma:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtAliciFirma" Width="200" IsReadOnly="True" Height="22" />
                <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                    <TextBlock Text="Aktif Rezervasyon Seç:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,6,0"/>
                    <ComboBox x:Name="cmbAktifRezervasyon" Width="150" SelectionChanged="cmbAktifRezervasyon_SelectionChanged"/>
                </StackPanel>
                <Button x:Name="BtnSevkiyatiTamamla" Content="Sevkiyatı Tamamla" Width="150" Height="28" Margin="12,0,0,0" Click="BtnSevkiyatiTamamla_Click"/>
            </StackPanel>

            <!-- 📄 Rezervasyon EPC Detayları -->
            <GroupBox Header="Rezervasyondaki Ürünler" Grid.Row="1" Margin="0,0,0,8" BorderBrush="#B197FC" BorderThickness="2" Padding="1" Background="#F9FFFFFF">
                
                <DataGrid x:Name="dataGridRezervasyonDetay"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          AlternatingRowBackground="White"
                          HeadersVisibility="Column"
                          RowBackground="#EEE"
                          Margin="6"
                          Height="150">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="EPC" Binding="{Binding [EPC]}"/>
                        <DataGridTextColumn Header="Barkod No" Binding="{Binding [BarkodNo]}"/>
                        <DataGridTextColumn Header="Bandil No" Binding="{Binding [BandilNo]}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- ✅ Uygun EPC'ler -->
            <GroupBox Header="Sevkiyata Uygun Ürünler" Grid.Row="2" Margin="0,0,0,8" BorderBrush="#B197FC" BorderThickness="2" Padding="1" Background="#F9FFFFFF">
                <!-- StackPanel yerine Grid: * + Auto -->
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dataGridUygun"
                              Grid.Row="0"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              CanUserAddRows="False"
                              AlternatingRowBackground="White"
                              RowBackground="LightGreen"
                              Margin="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="EPC" Binding="{Binding [EPC]}"/>
                            <DataGridTextColumn Header="Barkod" Binding="{Binding [BarkodNo]}"/>
                            <DataGridTextColumn Header="BandilNo" Binding="{Binding [BandilNo]}"/>
                            <DataGridTextColumn Header="Durum" Binding="{Binding [Durum]}"/>
                            <DataGridTextColumn Header="RezervasyonNo" Binding="{Binding [RezervasyonNo]}"/>
                            <DataGridTemplateColumn Header="Sabit">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding [IsFixed], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button x:Name="BtnTumunuSabitle"
                            Grid.Row="1"
                            Content="Tümünü Sabitle"
                            Width="150" Height="26"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Right"
                            Click="BtnTumunuSabitle_Click"/>
                </Grid>
            </GroupBox>

            <!-- ❌ Uygun Olmayan EPC'ler -->
            <GroupBox Header="Sevkiyata Uygun Olmayan Ürünler" Grid.Row="3" Margin="0" BorderBrush="#B197FC" BorderThickness="2" Padding="1" Background="#F9FFFFFF">
                <DataGrid x:Name="dataGridUygunsuz"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          CanUserAddRows="False"
                          AlternatingRowBackground="White"
                          RowBackground="IndianRed"
                          Margin="6">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="EPC" Binding="{Binding [EPC]}"/>
                        <DataGridTextColumn Header="Barkod" Binding="{Binding [BarkodNo]}"/>
                        <DataGridTextColumn Header="BandilNo" Binding="{Binding [BandilNo]}"/>
                        <DataGridTextColumn Header="Durum" Binding="{Binding [Durum]}"/>
                        <DataGridTextColumn Header="RezervasyonNo" Binding="{Binding [RezervasyonNo]}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

        </Grid>
    </Grid>
</Page>
