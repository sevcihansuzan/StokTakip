<Window x:Class="SideBar_Nav.Windows.IptalDetayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        BorderBrush="#FFB197FC" BorderThickness="1" 
        Title="İptal Detayları" Height="350" Width="450" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock x:Name="txtBilgi" TextWrapping="Wrap"/>
            <TextBlock Text="İptal Sebebi:" Margin="0,10,0,5" FontWeight="Bold"/>
            <ScrollViewer Height="200">
                <TextBlock x:Name="txtSebep" TextWrapping="Wrap"/>
            </ScrollViewer>
            <Button Content="Kapat" Width="80" HorizontalAlignment="Right" Margin="0,10,0,0" Click="BtnKapat_Click"/>
        </StackPanel>
    </Grid>
</Window>
