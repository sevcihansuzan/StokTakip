<Window x:Class="SideBar_Nav.Windows.PackingListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        BorderBrush="#FFB197FC" BorderThickness="1"
        Title="Packing List" Height="700" Width="1100">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="PACKING LIST" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10" />

            <UniformGrid Columns="2" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" Margin="0,0,10,5">
                    <TextBlock Text="Rezervasyon No:" FontWeight="Bold" Margin="0,0,5,0" />
                    <TextBlock x:Name="lblRezervasyonNo" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,10,5">
                    <TextBlock Text="Rezervasyon Kodu:" FontWeight="Bold" Margin="0,0,5,0" />
                    <TextBlock x:Name="lblRezervasyonKodu" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,10,5">
                    <TextBlock Text="Alıcı Firma:" FontWeight="Bold" Margin="0,0,5,0" />
                    <TextBlock x:Name="lblAliciFirma" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,10,5">
                    <TextBlock Text="Rezervasyon Sorumlusu:" FontWeight="Bold" Margin="0,0,5,0" />
                    <TextBlock x:Name="lblRezervasyonSorumlusu" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,10,5">
                    <TextBlock Text="Satış Sorumlusu:" FontWeight="Bold" Margin="0,0,5,0" />
                    <TextBlock x:Name="lblSatisSorumlusu" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,10,5">
                    <TextBlock Text="Durum:" FontWeight="Bold" Margin="0,0,5,0" />
                    <TextBlock x:Name="lblDurum" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,10,5">
                    <TextBlock Text="İşlem Tarihi:" FontWeight="Bold" Margin="0,0,5,0" />
                    <TextBlock x:Name="lblIslemTarihi" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,10,5">
                    <TextBlock Text="Ürün Çıkış Tarihi:" FontWeight="Bold" Margin="0,0,5,0" />
                    <TextBlock x:Name="lblUrunCikisTarihi" />
                </StackPanel>
            </UniformGrid>

            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="Sevkiyat Adresi:" FontWeight="Bold" />
                <TextBlock x:Name="txtSevkiyatAdresi" TextWrapping="Wrap" />
            </StackPanel>

            <UniformGrid Columns="4" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                    <TextBlock Text="Toplam Ürün:" FontWeight="Bold" Margin="0,0,5,0" />
                    <TextBlock x:Name="lblToplamUrun" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                    <TextBlock Text="Toplam Plaka Adedi:" FontWeight="Bold" Margin="0,0,5,0" />
                    <TextBlock x:Name="lblToplamPlaka" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                    <TextBlock Text="Toplam Satış Alanı:" FontWeight="Bold" Margin="0,0,5,0" />
                    <TextBlock x:Name="lblToplamAlan" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Toplam Satış Tonajı:" FontWeight="Bold" Margin="0,0,5,0" />
                    <TextBlock x:Name="lblToplamTonaj" />
                </StackPanel>
            </UniformGrid>

            <UniformGrid Columns="2" Margin="0,0,0,10">
                <StackPanel Margin="0,0,10,5">
                    <TextBlock Text="PDF Oluşturma:" FontWeight="Bold" Margin="0,0,5,0" />
                    <TextBlock x:Name="lblPdfGeneratedAt" />
                    <TextBlock Text="PDF Dosya:" FontWeight="Bold" Margin="10,8,5,0" />
                    <TextBlock x:Name="lblPdfFileName" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Margin="0,0,10,5">
                    <TextBlock Text="Excel Oluşturma:" FontWeight="Bold" Margin="0,0,5,0" />
                    <TextBlock x:Name="lblExcelGeneratedAt" />
                    <TextBlock Text="Excel Dosya:" FontWeight="Bold" Margin="10,8,5,0" />
                    <TextBlock x:Name="lblExcelFileName" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </UniformGrid>
        </StackPanel>

        <WrapPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button x:Name="btnRefresh" Content="Yenile" Width="110" Height="30" Margin="0,0,10,0" Click="BtnRefresh_Click" />
            <Button x:Name="btnDownloadPdf" Content="PDF İndir" Width="110" Height="30" Margin="0,0,10,0" Click="BtnDownloadPdf_Click" />
            <Button x:Name="btnPrintPdf" Content="PDF Yazdır" Width="110" Height="30" Margin="0,0,10,0" Click="BtnPrintPdf_Click" />
            <Button x:Name="btnDownloadExcel" Content="Excel İndir" Width="110" Height="30" Click="BtnDownloadExcel_Click" />
        </WrapPanel>

        <Border Grid.Row="2" BorderBrush="#FFB197FC" BorderThickness="1">
            <TabControl>
                <TabItem Header="PDF Önizleme">
                    <WebBrowser x:Name="pdfBrowser" />
                </TabItem>
                <TabItem Header="Excel Önizleme">
                    <WebBrowser x:Name="excelBrowser" />
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
