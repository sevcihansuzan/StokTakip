<Window x:Class="SideBar_Nav.Windows.BarcodeSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:SideBar_Nav.Services"
        Title="Barkod Okuyucu Ayarları" Width="980" Height="640"
        WindowStartupLocation="CenterOwner">

    <!-- ===== Modern, açık tema kaynakları ===== -->
    <Window.Resources>
        <!-- Renk paleti -->
        <SolidColorBrush x:Key="BgWindow"         Color="#F5F7FB"/>
        <SolidColorBrush x:Key="BgCard"           Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderCard"       Color="#E5E7EB"/>
        <SolidColorBrush x:Key="TextPrimary"      Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary"    Color="#475569"/>
        <SolidColorBrush x:Key="Accent"           Color="#4F46E5"/>
        <SolidColorBrush x:Key="AccentHover"      Color="#4338CA"/>
        <SolidColorBrush x:Key="RowAlt"           Color="#F2F4F8"/>
        <SolidColorBrush x:Key="RowBase"          Color="#FFFFFF"/>
        <SolidColorBrush x:Key="RowSelected"      Color="#E8EBFF"/>
        <SolidColorBrush x:Key="HeaderBg"         Color="#F3F4F6"/>
        <SolidColorBrush x:Key="HeaderBorder"     Color="#E5E7EB"/>

        <!-- TextBox watermark (placeholder) -->
        <Style TargetType="TextBox" x:Key="WatermarkTextBox">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderCard}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"/>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="8,6,8,6"/>
                            <TextBlock x:Name="wm"
                                       Text="{TemplateBinding Tag}"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="12,6,8,6"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="wm" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern buton -->
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="4,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- İkincil buton (beyaz) -->
        <Style TargetType="Button" x:Key="SecondaryButton" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderCard}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFBFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid modern + zebra -->
        <Style TargetType="DataGrid" x:Key="ModernGrid">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderCard}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="{StaticResource RowBase}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource RowAlt}"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource HeaderBorder}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource HeaderBorder}"/>
            <Setter Property="RowHeight" Value="36"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="ColumnHeaderHeight" Value="36"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <!-- Satır seçimi rengi -->
        <Style TargetType="DataGridRow">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="KeyboardNavigation.TabNavigation" Value="Local"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="DGR_Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0">
                            <SelectiveScrollingGrid>
                                <SelectiveScrollingGrid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </SelectiveScrollingGrid.ColumnDefinitions>
                                <SelectiveScrollingGrid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </SelectiveScrollingGrid.RowDefinitions>
                                <DataGridCellsPresenter Grid.Column="1"/>
                                <DataGridDetailsPresenter Grid.Row="1" Grid.Column="1"
                                                          Visibility="{TemplateBinding DetailsVisibility}"/>
                            </SelectiveScrollingGrid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="DGR_Border" Property="Background" Value="{StaticResource RowSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid ColumnHeader görünümü -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HeaderBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
    </Window.Resources>

    <!-- ===== Layout ===== -->
    <Grid Background="{StaticResource BgWindow}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="170"/>
        </Grid.RowDefinitions>

        <!-- Üst şerit (card) -->
        <Border Background="{StaticResource BgCard}" CornerRadius="14" BorderBrush="{StaticResource BorderCard}"
                BorderThickness="1" Margin="16" Padding="12">
            <StackPanel Orientation="Horizontal" >
                <Button Content="Serial Port: ON" Click="BtnSerialPortOpen_Click" Style="{StaticResource SecondaryButton}"/>
                <Button Content="Config Mode: ON" Click="BtnConfigOn_Click" Style="{StaticResource SecondaryButton}"/>
                <Button Content="Config Mode: OFF" Click="BtnConfigOff_Click" Style="{StaticResource SecondaryButton}"/>
                <Button Content="Save User Default" Click="BtnSaveUserDefault_Click" Style="{StaticResource SecondaryButton}"/>
                <Button Content="Restore User Default" Click="BtnRestoreUserDefault_Click" Style="{StaticResource SecondaryButton}"/>
                <Button Content="Factory Reset" Click="BtnFactoryReset_Click" Style="{StaticResource SecondaryButton}" Margin="0"/>
            </StackPanel>
        </Border>

        <!-- Orta alan (arama + grid) -->
        <Border Grid.Row="1" Background="{StaticResource BgCard}" CornerRadius="14" BorderBrush="{StaticResource BorderCard}"
                BorderThickness="1" Margin="16" Padding="12">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBox x:Name="txtSearch"
                             Width="300"
                             Style="{StaticResource WatermarkTextBox}"
                             svc:PlaceholderService.Placeholder="Ara (ad/kod/açıklama)"
                             TextChanged="txtSearch_TextChanged"
                             Margin="0,0,8,0"/>
                    <ComboBox x:Name="cmbCategory"
                              Width="200"
                              Background="{StaticResource BgCard}"
                              Foreground="{StaticResource TextPrimary}"
                              BorderBrush="{StaticResource BorderCard}"
                              Padding="8,6"
                              SelectionChanged="cmbCategory_SelectionChanged"
                              Margin="0,0,8,0"/>
                   
                </StackPanel>

                <DataGrid x:Name="dgCommands"
                          Style="{StaticResource ModernGrid}"
                          AlternationCount="2"
                          AutoGenerateColumns="False">
                    
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="150"/>
                        <DataGridTextColumn Header="Ad"       Binding="{Binding Name}"     Width="*"/>
                        <DataGridTextColumn Header="Komut"    Binding="{Binding Code}"     Width="240"/>
                        <DataGridTextColumn Header="Açıklama" Binding="{Binding Description}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- Alt (komut gönder + log) -->
        <Border Grid.Row="2" Background="{StaticResource BgCard}" CornerRadius="14" BorderBrush="{StaticResource BorderCard}"
                BorderThickness="1" Margin="16" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="txtDirectCode"
                             Width="460"
                             Style="{StaticResource WatermarkTextBox}"
                             svc:PlaceholderService.Placeholder="Doğrudan komut yaz (örn: ~M00210003.)"
                             Margin="0,0,8,0"/>
                    <Button Content="Seçileni Gönder" Click="BtnSendSelected_Click" Style="{StaticResource PrimaryButton}"/>
                    <Button Content="Doğrudan Gönder" Click="BtnSendDirect_Click" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="Tetikle (~T.)" Click="BtnTrigger_Click" Style="{StaticResource SecondaryButton}" Margin="0"/>
                </StackPanel>

                <TextBox x:Name="txtLog" Grid.Row="1"
                         IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="#FFFFFF"
                         Foreground="{StaticResource TextSecondary}"
                         BorderBrush="{StaticResource BorderCard}"
                         BorderThickness="1"
                         Padding="10"/>
            </Grid>
        </Border>
    </Grid>
</Window>
