<Window x:Class="SideBar_Nav.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kayıt Ol" Height="540" Width="460"
        WindowStartupLocation="CenterOwner"
        Background="#0F1115"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True">
    <Grid Margin="16">
        <Border Background="#1A1F2B" CornerRadius="16" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 0: Başlık -->
                    <RowDefinition Height="12"/>
                    <!-- 1: Boşluk -->
                    <RowDefinition Height="Auto"/>
                    <!-- 2: Ad -->
                    <RowDefinition Height="8"/>
                    <!-- 3: Boşluk -->
                    <RowDefinition Height="Auto"/>
                    <!-- 4: Email -->
                    <RowDefinition Height="8"/>
                    <!-- 5: Boşluk -->
                    <RowDefinition Height="Auto"/>
                    <!-- 6: Telefon (YENİ) -->
                    <RowDefinition Height="8"/>
                    <!-- 7: Boşluk (YENİ) -->
                    <RowDefinition Height="Auto"/>
                    <!-- 8: Parola (kaydı) -->
                    <RowDefinition Height="16"/>
                    <!-- 9: Boşluk büyük -->
                    <RowDefinition Height="Auto"/>
                    <!-- 10: Durum etiketi -->
                    <RowDefinition Height="12"/>
                    <!-- 11: Boşluk -->
                    <RowDefinition Height="Auto"/>
                    <!-- 12: Butonlar -->
                </Grid.RowDefinitions>

                <TextBlock Text="Yeni Hesap Oluştur" FontSize="20" FontWeight="Bold" Foreground="#F3F4F6"/>

                <!-- Ad (opsiyonel, yalnızca UI) -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="Ad (opsiyonel)" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtFullName"
                             Height="38"
                             Padding="10,0"
                             Background="#111827"
                             Foreground="#E5E7EB"
                             BorderBrush="#374151"
                             BorderThickness="1"/>
                </StackPanel>

                <!-- Email -->
                <StackPanel Grid.Row="4">
                    <TextBlock Text="Email" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtEmail"
                             Height="38"
                             Padding="10,0"
                             Background="#111827"
                             Foreground="#E5E7EB"
                             BorderBrush="#374151"
                             BorderThickness="1"/>
                </StackPanel>

                <!-- Telefon (opsiyonel) -->
                <StackPanel Grid.Row="6">
                    <TextBlock Text="Telefon (opsiyonel)" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtPhone"
                             Height="38"
                             Padding="10,0"
                             Background="#111827"
                             Foreground="#E5E7EB"
                             BorderBrush="#374151"
                             BorderThickness="1"/>
                </StackPanel>

                <!-- Parola -->
                <StackPanel Grid.Row="8">
                    <TextBlock Text="Parola" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="txtPassword"
                                 Height="38"
                                 Padding="10,0"
                                 Background="#111827"
                                 Foreground="#E5E7EB"
                                 BorderBrush="#374151"
                                 BorderThickness="1"/>
                </StackPanel>

                <!-- Durum -->
                <TextBlock x:Name="lblStatus"
                           Grid.Row="10"
                           Foreground="#FCA5A5"
                           TextWrapping="Wrap" />

                <!-- Butonlar -->
                <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnCancel"
                            Content="İptal"
                            Margin="0,0,8,0"
                            Click="btnCancel_Click"
                            Background="Transparent"
                            BorderBrush="#374151"
                            Foreground="#E5E7EB"
                            Padding="14,6"/>
                    <Button x:Name="btnRegister"
                            Content="Hesap Oluştur"
                            Click="btnRegister_Click"
                            Background="#4F46E5"
                            BorderBrush="#4338CA"
                            Foreground="White"
                            Padding="18,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Busy -->
        <Border x:Name="busyOverlay" Background="#80000000" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="220" Height="6"/>
                <TextBlock Text="İşlem yapılıyor..." Margin="0,8,0,0" Foreground="#E5E7EB" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

