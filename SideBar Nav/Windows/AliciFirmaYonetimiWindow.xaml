<Window x:Class="SideBar_Nav.Windows.AliciFirmaYonetimiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        BorderBrush="#FFB197FC" BorderThickness="1" 
        Title="Alıcı Firma Yönetimi" Height="800" Width="900" WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 🔍 Arama Kutusu -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Firma Ara:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="txtArama" Width="200" TextChanged="txtArama_TextChanged"/>
            </StackPanel>

            <!-- 📝 Firma Bilgileri -->
            <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,10">
                <WrapPanel Margin="0,5">
                    <TextBlock Text="Firma Adı:" Width="120" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtFirmaAdi" Width="200"/>

                    <TextBlock Text="Vergi No:" Width="50" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="txtVergiNo" Width="150" Margin="5,0"/>
                </WrapPanel>
                <WrapPanel Margin="0,5">
                    <TextBlock Text="Vergi Dairesi:" Width="120" VerticalAlignment="Center" />
                    <TextBox x:Name="txtVergiDairesi" Width="200"/>

                    <TextBlock Text="Telefon:" Width="50" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="txtTelefon" Width="150" Margin="5,0"/>
                </WrapPanel>
                <WrapPanel Margin="0,5">
                    <TextBlock Text="Yetkili Adı:" Width="120" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtYetkili" Width="200"/>

                    <TextBlock Text="Email:" Width="50" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="txtEmail" Width="200" Margin="5,0"/>
                </WrapPanel>
                <WrapPanel Margin="0,5">
                    <TextBlock Text="Ülke:" Width="120" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtUlke" Width="200"/>
                    <TextBlock Text="Şehir:" Width="30" VerticalAlignment="Center" Margin="5,0,0,0" />
                    <TextBox x:Name="txtSehir" Width="100" Margin="5,0"/>
                    <TextBlock Text="İlçe:" Width="30" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtIlce" Width="100" Margin="5,0"/>
                    <TextBlock Text="Posta Kodu:" Width="65" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtPostaKodu" Width="80" Margin="5,0"/>
                </WrapPanel>
                <WrapPanel Margin="0,5">
                    <TextBlock Text="Sevkiyat Adresi:" Width="120" VerticalAlignment="Top"/>
                    <TextBox x:Name="txtSevkiyatAdresi" Width="700" Height="50" AcceptsReturn="True" TextWrapping="Wrap"/>
                </WrapPanel>
                <WrapPanel Margin="0,5">
                    <TextBlock Text="Fatura Adresi:" Width="120" VerticalAlignment="Top"/>
                    <TextBox x:Name="txtFaturaAdresi" Width="700" Height="50" AcceptsReturn="True" TextWrapping="Wrap"/>
                </WrapPanel>
                <WrapPanel Margin="0,5">
                    <TextBlock Text="Notlar:" Width="120" VerticalAlignment="Top"/>
                    <TextBox x:Name="txtNotlar" Width="700" Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                </WrapPanel>
            </StackPanel>

            <!-- 📋 Firma Listesi -->
            <DataGrid x:Name="dataGridFirmalar"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      Height="250"
                      SelectionChanged="dataGridFirmalar_SelectionChanged"
                      Margin="0,0,0,10"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Firma Adı" Binding="{Binding FirmaAdi}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 🔘 İşlem Butonları -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Yeni Ekle" Width="100" Margin="5" Click="BtnYeniEkle_Click"/>
                <Button Content="Firma Bilgilerini Güncelle" Width="150" Margin="5" Click="BtnGuncelle_Click"/>
                <Button Content="Sil" Width="100" Margin="5" Click="BtnSil_Click"/>
                <Button Content="Seç ve Kapat" Width="120" Margin="5" Click="BtnSecKapat_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
