<Window x:Class="SideBar_Nav.Windows.YuzeyIslemiEkleWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Title="Yüzey İşlemi Yönetimi"
       Height="400" Width="400"
       WindowStartupLocation="CenterScreen"
       BorderBrush="#FFB197FC" BorderThickness="1" 
       ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Yeni yüzey işlemi ekleme alanı -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">

            <!-- TextBox + Placeholder -->
            <Grid Width="200" Margin="0,0,10,0">
                <TextBox x:Name="txtYuzeyIslemi"
                         VerticalContentAlignment="Center"
                         Padding="8"/>
                <!-- Placeholder -->
                <TextBlock Text="Yüzey işlemi girin…"
                           Foreground="#9CA3AF"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Text, ElementName=txtYuzeyIslemi}" Value=""/>
                                        <Condition Binding="{Binding IsKeyboardFocused, ElementName=txtYuzeyIslemi}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Button Content="Ekle" Width="80" Click="BtnEkle_Click"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="dataGridYuzeyIslemleri" Grid.Row="1" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="False"
                  CellEditEnding="DataGridYuzeyIslemleri_CellEditEnding"
                  SelectionMode="Single" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>
                <DataGridTextColumn Header="Yüzey İşlemi" Binding="{Binding YuzeyIslemi}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Alt butonlar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Yenile" Width="80" Margin="0,0,10,0" Click="BtnYenile_Click"/>
            <Button Content="Sil" Width="80" Click="BtnSil_Click"/>
        </StackPanel>
    </Grid>
</Window>
