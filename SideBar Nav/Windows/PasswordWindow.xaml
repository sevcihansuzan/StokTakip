<Window x:Class="SideBar_Nav.Windows.PasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        BorderBrush="#FFB197FC" BorderThickness="1" 
        Title="Şifre Oluştur/Yenile" Height="260" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="E-posta:" Margin="0,0,8,8"/>
        <TextBox x:Name="txtEmail" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" IsReadOnly="True"/>

        <Label x:Name="lblCurrent" Grid.Row="1" Grid.Column="0" Content="Mevcut Şifre:" Margin="0,0,8,8"/>
        <PasswordBox x:Name="txtCurrentPassword" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Yeni Şifre:" Margin="0,0,8,8"/>
        <PasswordBox x:Name="txtNewPassword" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Yeni Şifre (Tekrar):" Margin="0,0,8,8"/>
        <PasswordBox x:Name="txtConfirmPassword" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>

        <TextBlock x:Name="lblStatus" Grid.Row="4" Grid.ColumnSpan="2" Foreground="IndianRed" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnSave" Content="Kaydet" Width="80" Margin="0,0,5,0" Click="btnSave_Click"/>
            <Button Content="Kapat" Width="80" Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>